# MongoDB 連線字串 (必填)
# 格式: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<appName>

# 資料庫名稱 (選填，預設為 scheduleApp)
DB_NAME=scheduleApp

# 伺服器埠號 (選填，預設為 3000)
PORT=3000

# JWT 密鑰（與 accounting-system 共用同一個值）
# 設定後所有 API 需登入才能使用；未設定時系統完全開放
JWT_SECRET=

# CORS 允許的來源（選填）；未設定則允許全部（*）
# 部署後建議填入實際網址，例：https://yourapp.zeabur.app
CORS_ORIGIN=

# 應用程式公開網址（用於忘記密碼郵件中的重設連結）
# 必須填入，否則重設連結會指向 localhost
APP_URL=https://yourapp.zeabur.app

# Gmail SMTP（用於忘記密碼功能）
# 設定步驟：啟用兩步驟驗證 → 生成「應用程式密碼」（16位）
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=
SMTP_FROM_NAME=排班系統 - 系統通知
