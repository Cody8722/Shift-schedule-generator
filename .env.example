# MongoDB 連線字串 (必填)
# 格式: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGODB_URI=mongodb+srv://DB_USER_REDACTED:REDACTED_PASSWORD@CLUSTER_REDACTED.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# 資料庫名稱 (選填，預設為 scheduleApp)
DB_NAME=scheduleApp

# 伺服器埠號 (選填，預設為 3000)
PORT=3000

# 存取密碼（選填）；設定後所有 API 需登入才能使用
# 未設定時系統完全開放（適合內網或開發環境）
ACCESS_PASSWORD=

# CORS 允許的來源（選填）；未設定則允許全部（*）
# 部署後建議填入實際網址，例：https://yourapp.zeabur.app
CORS_ORIGIN=
